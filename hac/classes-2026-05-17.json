        (function($) {
            $(document).ready(function() {
                $(function() {
                    $(window).on('scroll', function() {
                        if ($('.ca-nav-menu li.collapse-button').is(':visible')) {
                            $('#ca-header .top-area').show();
                        } else {
                            if ($(window).scrollTop() === 0) {
                                $('#ca-header .top-area').show();
                            } else {
                                $('#ca-header .top-area').hide();
                            }
                        }
                    });

                    $('#logout-button').on('click', function() {
                        window.location.replace("/user/logout");

                        return false;
                    });

                    $('.ca-nav-menu .on-click').on('click', function() {
                        if ($(this).hasClass('child-expanded')) {
                            $(this).find('> ul').hide();
                            $(this).removeClass('child-expanded');
                            $('#ca-header').removeClass('z-index-1100');
                        } else {
                            $(this).find('> ul').show();
                            $(this).addClass('child-expanded');
                            $('#ca-header').addClass('z-index-1100');
                        }
                    }).on('mouseleave', function() {
                        if (!$('.ca-nav-menu li.collapse-button').is(':visible')) {
                            $(this).find('> ul').hide();
                            $(this).removeClass('child-expanded');
                            $('#ca-header').removeClass('z-index-1100');
                        }
                    });

                                        $('#show-change-user-role-dialog').caChangeUserRole();

                    var toogleNavbar = function (event) {
                        event.preventDefault();
                        var navbar = $(this).parents('.ca-nav-menu');

                        if (navbar.hasClass('expanded')) {

                            navbar.removeClass('expanded');
                        } else {
                            navbar.addClass('expanded');
                        }
                    }

                    $('.collapse-button').on('click', toogleNavbar);
                });
            });
        })(jQuery);

