            <script type="text/javascript">
            jQuery(document).ready(function($) {
                var Bubble = function(linkObject, userId){
                    this.pos = linkObject.offset();
                    this.width = linkObject.width();
                    this.height = linkObject.height();
                    this.currId = '#user-info-'+userId;

                    var constract = function(thisObj){
                        if(document.getElementById('user-info-'+userId) == null){
                            $('body').append('<div class="user-info bubble" id="user-info-'+userId+'">'+$('#user-info-pop-up').html()+'</div>');
                            $('#user-info-'+userId+' div.loading').show();
                            var params = new Object();
                            params.userId = userId;
                            $.ajax({
                                type: 'POST',
                                url: '/profile/get-bubble-info',
                                data: params,
                                success:function(dataJson){
                                    var data = JSON.parse(dataJson);
                                    $('#user-info-'+userId+' form.user-info-mail-form .user-info-mail-form-emails-ids').val(userId);
                                    $('#user-info-'+userId+' button.user-info-email-button').on('click', function(){
                                        $('#user-info-'+userId+' form.user-info-mail-form').submit();
                                    });

                                    if (data.name) {
                                        var nameBlock = (data.isArchived)
                                            ? $('<span></span>').html(data.name)
                                            : $('<a href="/user/edit?id=' + userId + '"></a>').html(data.name);

                                        $('#user-info-'+userId+' .user-info-name h3').html(nameBlock);
                                    }

                                    if (data.status) {
                                        $('#user-info-'+userId+' .user-info-status').html(data.status);
                                        $('#user-info-'+userId+' .user-info-status').addClass(data.statusClass);
                                    }

                                    if (data.cc_number) {
                                        $('#user-info-'+userId+' .user-info-cc').html('<span class="extra-info">(' + data.cc_type + ' ' + data.cc_number + ')</span>');
                                    }

                                    if (data.balance){
                                        $('#user-info-'+userId+' .user-info-balance').html(data.balance);
                                    }

                                    if (data.email) {
                                        var emailBlock = (data.isArchived)
                                            ? $('<span></span>').html(data.email)
                                            : $('<a onclick="$j(\'form.user-info-mail-form\').submit();"></a>').html(data.email);

                                        $('#user-info-'+userId+' div.user-info-contacts-email').html(emailBlock);
                                    }

                                    if (data.phone) {
                                        $('#user-info-'+userId+' div.user-info-contacts-phone').html(data.phone);
                                    }

                                    if (data.rank) {
                                        $('#user-info-'+userId+' div.user-info-rank').html(data.rank);
                                    }

                                    if (data.go_to_pos) {
                                        $('#user-info-'+userId+' button.user-info-gotopos-button').show();
                                        $('#user-info-'+userId+' button.user-info-gotopos-button').on('click', function(){
                                            location.href = data.go_to_pos;
                                        });
                                    } else {
                                        $('#user-info-'+userId+' button.user-info-gotopos-button').hide();
                                    }

                                    if (data.go_to_payroll) {
                                        $('#user-info-'+userId+' button.user-info-gotopayroll-button').show();
                                        $('#user-info-'+userId+' button.user-info-gotopayroll-button').on('click',function(){
                                            location.href = data.go_to_payroll;
                                        });
                                    } else {
                                        $('#user-info-'+userId+' button.user-info-gotopayroll-button').hide();
                                    }

                                    if (data.filename) {
                                        $('#user-info-'+userId+' div.user-info-icon').html('<img src="'+data.filename+'" alt="'+data.name+'"/>');
                                    }

                                    if($('#user-info-'+userId+' div.loading').css('display') == 'block') {
                                        $('#user-info-'+userId+' div.loading').hide();
                                        thisObj.show(true);
                                    } else {
                                        $('#user-info-'+userId+' div.loading').hide();
                                    }
                                },
                                error: function(jqXHR, exception) {
                                    var message = 'System error occurred: ' + jqXHR.responseText;
                                    if (jqXHR.status === 0) {
                                        message = 'Not connected. Please verify your network connection.';
                                    } else if (jqXHR.status == 404) {
                                        message = 'The requested page not found.';
                                    } else if (jqXHR.status == 500) {
                                        message = 'Internal Server Error.';
                                    } else if (exception === 'parsererror') {
                                        message = 'Requested JSON parse failed.';
                                    } else if (exception === 'timeout') {
                                        message = 'Time out error.';
                                    } else if (exception === 'abort') {
                                        message = 'Ajax request aborted.';
                                    }

                                    $('#user-info-' + userId + ' div.loading').hide();
                                    $('div.user-info').hide();

                                    if (typeof(jQuery.caAlert) == 'function') {
                                        $.caAlert(message);
                                    } else {
                                        alert(message);
                                    }
                                },
                                dataType: 'html'
                            });
                        }
                    }
                    constract(this);
                    this.show = function(afterAjax){
                        var local = this.getLocation();
                        if(local.w == 'right'){
                            $(this.currId).css('left', parseInt(this.pos.left));
                            $(this.currId+' div.trg-up').css('left',30);
                            $(this.currId+' div.trg-down').css('left',30);
                        }else if(local.w == 'left'){
                            $(this.currId).css('left', parseInt(this.pos.left)+this.width - 320);
                            $(this.currId+' div.trg-up').css('left',320-52);
                        }
                        if(local.h == 'bottom'){
                            $(this.currId).css('top', parseInt(this.pos.top)+this.height);
                            $(this.currId+' div.trg-down').hide();
                            $(this.currId+' div.trg-up').show();
                        }else if(local.h == 'top'){
                            var h = this.getInfoHeight();
                            $(this.currId).css('top', (parseInt(this.pos.top)-(h+42+parseInt(this.height))));
                            $(this.currId+' div.trg-up').hide();
                            $(this.currId+' div.trg-down').show();
                        }

                        $('div.user-info').hide();
                        $(this.currId).show();

                        // can hide only after ajax complete
                        if (afterAjax == true) {
                            $('div.user-info').on('mouseover', function() {
                                $('div.user-info').on('mouseleave', function(){
                                    $('div.user-info').hide();
                                });
                            });
                        }

                        if (local.h == 'top') {
                            $(this.currId).css('top', (parseInt(linkObject.offset().top)-parseInt($(this.currId+' .info').height())) - 20);
                        }
                    }
                    this.getInfoHeight = function(){
                        $('#user-info-'+userId).show();
                        if($('#user-info-'+userId+' div.loading').css('display') == 'block'){
                            var height = 177;
                        }else{
                            var height = $('#user-info-'+userId+' div.user-info-top').height();
                        }
                        $('#user-info-'+userId).hide();
                        return parseInt(height);
                    }
                    this.getLocation = function(){
                        var result = new Object();
                        result.w = 'right';
                        result.h = 'bottom';
                        if((this.pos.left+320) > $(window).width()){
                            result.w = 'left';
                        }
                        if((this.pos.top+(this.getInfoHeight()+41+this.height)) > $(window).height()){
                            result.h = 'top';
                        }
                        return result;
                    }
                };

                $.fn.userBubbleMouseover = function() {
                    var self = this;
                    $(this).data('userBubble', setTimeout(function () {
                        $('div.user-info').hide();
                        var currId = $(self).attr('user-id');
                        var currBubble = new Bubble($(self), currId);
                        currBubble.show();
                    }, 1000));
                };

                $.fn.userBubbleMouseout = function() {
                    clearTimeout($(this).data('userBubble'));
                };

                $.fn.getUserBubbleLink = function(id, name) {
                    var userLink = '<a user-id="' + id + '" href="/user/edit?id=' + id + '" onmouseover="$j(this).userBubbleMouseover();" onmouseout="$j(this).userBubbleMouseout();">' + name + '</a>';
                    return userLink;
                }
            });
            </script>            
